{
  "name": "ai-news-daily",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "A web project that collects daily AI news (Vue 3 + Vite)",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "fetch-news": "node scripts/fetch-news.mjs",
    "type-check": "vue-tsc -b --noEmit"
  },
  "dependencies": {
    "vue": "^3.5.13",
    "vue-i18n": "^10.0.8"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "typescript": "~5.7.2",
    "vite": "^6.0.7",
    "vue-tsc": "^2.2.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
